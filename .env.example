# Copiez ce fichier en .env et remplissez les valeurs
# cp .env.example .env

# ── Environnement ─────────────────────────────────────────────
DEBUG=True   # False en production

# Générez une clé avec :
#   python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
SECRET_KEY=CHANGEZ_CETTE_CLE_EN_PRODUCTION

# Votre domaine (ex: childrensfruit.com,www.childrensfruit.com)
ALLOWED_HOSTS=localhost,127.0.0.1

# ── Google OAuth 2.0 ───────────────────────────────────────────
# console.cloud.google.com → APIs & Services → Identifiants
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://127.0.0.1:8000/accounts/google/callback/

# ── YouTube Data API v3 ────────────────────────────────────────
# console.cloud.google.com → APIs → YouTube Data API v3 → Clé API
YOUTUBE_API_KEY=
