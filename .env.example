# Copier ce fichier en .env et remplir les valeurs
# cp .env.example .env

# ── Environnement ─────────────────────────────────────────────
# True en local, False en production
DEBUG=True

# Générer une clé secrète avec :
#   python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
SECRET_KEY=CHANGEZ_CETTE_CLE_EN_PRODUCTION

# Domaines autorisés (séparés par des virgules)
# Local : localhost,127.0.0.1
# Production Railway : childrensfruit.up.railway.app
# Production Render  : childrensfruit.onrender.com
ALLOWED_HOSTS=localhost,127.0.0.1

# ── Base de données ────────────────────────────────────────────
# Laisser vide → SQLite (développement local)
# Railway / Render → fourni automatiquement via DATABASE_URL
DATABASE_URL=

# ── Google OAuth 2.0 ───────────────────────────────────────────
# 1. console.cloud.google.com
# 2. APIs & Services → Identifiants → Créer → ID client OAuth 2.0
# 3. Type : Application Web
# 4. URI de redirection autorisée :
#      Local      → http://127.0.0.1:8000/accounts/google/callback/
#      Render     → https://childrensfruit.onrender.com/accounts/google/callback/
#      Railway    → https://childrensfruit.up.railway.app/accounts/google/callback/
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://127.0.0.1:8000/accounts/google/callback/

# ── YouTube Data API v3 ────────────────────────────────────────
# 1. console.cloud.google.com
# 2. APIs & Services → Bibliothèque → YouTube Data API v3 → Activer
# 3. APIs & Services → Identifiants → Créer → Clé API
YOUTUBE_API_KEY=
YOUTUBE_CHANNEL=@CFRUIT24

# ── Email ─────────────────────────────────────────────────────
# Local (affiche dans la console) :
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
# Production SMTP (ex: Gmail) :
# EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
# EMAIL_HOST=smtp.gmail.com
# EMAIL_PORT=587
# EMAIL_USE_TLS=True
# EMAIL_HOST_USER=ton@email.com
# EMAIL_HOST_PASSWORD=mot_de_passe_app
